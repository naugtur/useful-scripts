#!/bin/bash
set -euo pipefail

# recordall - Record microphone and system audio simultaneously as separate files
# Requires: ffmpeg, pipewire (wpctl) or pulseaudio-utils (pactl)
# Usage: recordall [output_directory]

OUTPUT_DIR="${1:-.}"
TIMESTAMP="$(date +%Y%m%d-%H%M%S)"
MIC_FILE="${OUTPUT_DIR}/${TIMESTAMP}-mic.wav"
SYS_FILE="${OUTPUT_DIR}/${TIMESTAMP}-out.wav"

# Check dependencies
if ! command -v ffmpeg >/dev/null 2>&1; then
    echo "Error: 'ffmpeg' is not installed." >&2
    exit 1
fi

# Auto-detect the monitor source for system audio capture
# Try wpctl (PipeWire) first, fall back to pactl (PulseAudio)
if command -v wpctl >/dev/null 2>&1; then
    DEFAULT_SINK_NAME="$(wpctl inspect @DEFAULT_AUDIO_SINK@ 2>/dev/null \
        | grep 'node.name' | head -1 | sed 's/.*= "\(.*\)"/\1/')"
elif command -v pactl >/dev/null 2>&1; then
    DEFAULT_SINK_NAME="$(pactl info 2>/dev/null | grep 'Default Sink:' | cut -d' ' -f3)"
else
    echo "Error: Neither 'wpctl' (PipeWire) nor 'pactl' (PulseAudio) found." >&2
    echo "Install pipewire or pulseaudio-utils." >&2
    exit 1
fi

if [ -z "${DEFAULT_SINK_NAME:-}" ]; then
    echo "Error: Could not determine default audio output sink." >&2
    echo "Is PipeWire or PulseAudio running?" >&2
    exit 1
fi
MONITOR_SOURCE="${DEFAULT_SINK_NAME}.monitor"

# Verify the monitor source exists via ffmpeg's pulse source listing
if ! ffmpeg -sources pulse 2>/dev/null | grep -q "$MONITOR_SOURCE"; then
    echo "Error: Monitor source '${MONITOR_SOURCE}' not found." >&2
    echo "Available sources:" >&2
    ffmpeg -sources pulse 2>/dev/null | grep -E '^\s' >&2
    exit 1
fi

mkdir -p "$OUTPUT_DIR"

echo "Recording started at $(date +%H:%M:%S)"
echo "  Microphone -> ${MIC_FILE}"
echo "  System audio (${MONITOR_SOURCE}) -> ${SYS_FILE}"
echo "Press Ctrl+C to stop."
echo


cleanup() {
    echo
    echo "Stopping recording..."
    sleep 1
    kill "$MIC_PID" "$SYS_PID" 2>/dev/null || true
    wait "$MIC_PID" "$SYS_PID" 2>/dev/null || true
}
trap cleanup INT TERM

# Record microphone (default pulse source)
ffmpeg -nostdin -hide_banner -loglevel error -f pulse -i default \
    -ac 1 -ar 48000 "$MIC_FILE" &
MIC_PID=$!

# Record system audio (monitor of default sink)
ffmpeg -nostdin -hide_banner -loglevel error -f pulse -i "$MONITOR_SOURCE" \
    -ac 2 -ar 48000 "$SYS_FILE" &
SYS_PID=$!

# Wait for either process to exit (or Ctrl+C)
wait -n "$MIC_PID" "$SYS_PID" 2>/dev/null || true

echo "Recording  finished"
echo "Saved:"
[ -f "$MIC_FILE" ] && echo "  Microphone:    ${MIC_FILE} ($(du -h "$MIC_FILE" | cut -f1))"
[ -f "$SYS_FILE" ] && echo "  System audio:  ${SYS_FILE} ($(du -h "$SYS_FILE" | cut -f1))"

