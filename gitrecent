#!/bin/bash

# A script to find LOCAL git branches modified in the last N days,
# then optionally start an interactive merge process for them.
#
# Usage:
#   ./git-recent-branches [days] [pattern]

# --- Step 1: Find and Print Branches (The Familiar Script) ---

DAYS=${1:-7}
PATTERN=$2
CURRENT_BRANCH=$(git branch --show-current)

# Calculate the cutoff timestamp using portable shell math.
NOW_TIMESTAMP=$(date +s)
SECONDS_TO_SUBTRACT=$((DAYS * 86400))
CUTOFF_TIMESTAMP=$((NOW_TIMESTAMP - SECONDS_TO_SUBTRACT))

# Command pipeline to find, filter, and format branch names.
GIT_CMD="git for-each-ref \
    --sort=-committerdate \
    --format='%(committerdate:unix)	%(refname:short)' \
    refs/heads"

AWK_CMD="awk -F'\t' -v cutoff=\"$CUTOFF_TIMESTAMP\" -v current_branch=\"$CURRENT_BRANCH\" '
    \$1 > cutoff && \$2 != current_branch {
        print \$2 # Only print the branch name
    }
'"

# Build the filtering pipeline.
FILTER_PIPELINE="$GIT_CMD | $AWK_CMD"
if [ -n "$PATTERN" ]; then
  GREP_CMD="grep --color=auto -E \"$PATTERN\""
  FILTER_PIPELINE+=" | $GREP_CMD"
fi

# Execute the pipeline to get the list of branch names.
BRANCH_LIST=$(eval "$FILTER_PIPELINE")

# Check if any branches were found.
if [ -z "$BRANCH_LIST" ]; then
    echo "✅ No matching local branches found."
    exit 0
fi

# Display the final list of branches, as requested.
echo "Usage: gitrecent [days] [grep pattern] - Find branches modified in the last N days (default: 7)"
echo
echo "Found the following branches:"
echo "-------------------------------------"
echo "$BRANCH_LIST"
echo "-------------------------------------"


# --- Functions for Different Actions ---

# Function to perform interactive merging
perform_interactive_merge() {
    local branch_list="$1"
    local current_branch="$2"
    
    echo
    echo "Starting interactive merge into '$current_branch'..."
    
    # Iterate on the string of branch names captured above.
    for branch in $branch_list; do
        echo
        read -p "Merge branch '$branch'? [y/N] " -n 1 -r reply
        echo

        if [[ "$reply" =~ ^[Yy]$ ]]; then
            echo "Attempting to merge '$branch'..."
            git merge "$branch"

            if [ $? -ne 0 ]; then
                echo "❌ MERGE FAILED for branch '$branch'."
                read -p "A merge conflict likely occurred. Abort the merge? (git merge --abort) [y/N] " -n 1 -r abort_reply
                echo
                if [[ "$abort_reply" =~ ^[Yy]$ ]]; then
                    git merge --abort
                fi
            else
                echo "✅ Successfully merged '$branch'."
            fi
        else
            echo "Skipping branch '$branch'."
        fi
        echo "-------------------------------------"
    done

    echo "🎉 Interactive merge complete."
}

# Function to checkout one of the branches
checkout_branch() {
    local branch_list="$1"
    
    echo
    echo "Available branches:"
    local i=1
    for branch in $branch_list; do
        echo "$i) $branch"
        i=$((i + 1))
    done
    
    echo
    read -p "Enter the number of the branch to checkout (or 'q' to cancel): " choice
    
    if [[ "$choice" =~ ^[0-9]+$ ]]; then
        local selected_branch=$(echo "$branch_list" | sed -n "${choice}p")
        if [ -n "$selected_branch" ]; then
            echo "Checking out branch '$selected_branch'..."
            git checkout "$selected_branch"
            if [ $? -eq 0 ]; then
                echo "✅ Successfully checked out '$selected_branch'."
            else
                echo "❌ Failed to checkout '$selected_branch'."
            fi
        else
            echo "❌ Invalid selection."
        fi
    else
        echo "Checkout cancelled."
    fi
}

# Function to show detailed branch information
show_branches_with_details() {
    local branch_list="$1"
    
    echo
    echo "Branch details:"
    echo "=============================================="
    
    for branch in $branch_list; do
        echo "📋 Branch: $branch"
        # Get the latest commit message and date for this branch
        local commit_info=$(git log -n 1 --pretty=format:"%h - (%ci, %cr)%n%s" "$branch" 2>/dev/null)
        if [ $? -eq 0 ]; then
            echo "   Latest: $commit_info"
        else
            echo "   Latest: Unable to fetch commit info"
        fi
        echo "----------------------------------------------"
    done
    
    echo "✅ Branch details complete."
}

# Function to just show branches (current behavior)
show_branches_only() {
    exit 0
}

# --- Step 2: Interactive Menu ---

# Safety check for detached HEAD state (only needed for merge operations)
check_detached_head() {
    if [ -z "$CURRENT_BRANCH" ]; then
        echo "❌ Cannot merge: You are in a 'detached HEAD' state."
        return 1
    fi
    return 0
}

echo
echo "What would you like to do?"
echo "0) quit"
echo "1) Merge branches interactively into current:'$CURRENT_BRANCH'"
echo "2) Checkout one of the branches"
echo "3) Show branch details (latest commit info)"
echo
read -p "Choose an option: " -n 1 -r choice
echo

case "$choice" in
    1)
        if ! check_detached_head; then
            exit 1
        fi
        perform_interactive_merge "$BRANCH_LIST" "$CURRENT_BRANCH"
        ;;
    2)
        checkout_branch "$BRANCH_LIST"
        ;;
    3)
        show_branches_with_details "$BRANCH_LIST"
        ;;
    0)
        show_branches_only
        ;;
    *)
        echo "Invalid choice. Exiting."
        exit 1
        ;;
esac